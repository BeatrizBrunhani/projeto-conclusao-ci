{
  "name": "conclusao-ci",
  "version": "1.0.0",
  "description": "Projeto com pipeline CI/CD, testes automatizados e relatórios",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:report": "jest --coverage --collectCoverageFrom='src/**/*.js'",
    "test:mocha": "mocha 'tests/**/*.test.js' --require @babel/register",
    "test:mochawesome": "mocha 'tests/**/*.test.js' --require @babel/register --reporter mochawesome",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "start": "node src/index.js"
  },
  "keywords": [
    "ci",
    "cd",
    "testing",
    "mocha",
    "jest",
    "github-actions"
  ],
  "author": "Seu Nome",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "@babel/preset-env": "^7.22.0",
    "@babel/register": "^7.22.0",
    "babel-jest": "^29.5.0",
    "eslint": "^8.44.0",
    "jest": "^29.5.0",
    "jest-junit": "^16.0.0",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-report-generator": "^6.2.0"
  },
  "dependencies": {}
}